# AI Co-Scientist Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# =============================================================================
# LLM Providers
# =============================================================================

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google AI (Gemini) - https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSyAEUaXDkdB9OgDvEsLwda7ZVtyIVgguMHg

# OpenAI (optional fallback) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# =============================================================================
# LangSmith (Optional - for LangGraph tracing/debugging)
# =============================================================================

# LangSmith - https://smith.langchain.com/
# Free tier available, useful for debugging agent workflows
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=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
LANGCHAIN_PROJECT=ai-coscientist

# =============================================================================
# Search & RAG
# =============================================================================

# Tavily Search API - https://tavily.com/
TAVILY_API_KEY=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

# =============================================================================
# Database (Production)
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://coscientist:password@localhost:5432/coscientist

# Redis connection string (for caching/task queue)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Vector Storage
# =============================================================================

# ChromaDB (prototyping) - local file path
CHROMA_PERSIST_DIRECTORY=./data/chroma

# =============================================================================
# Model Configuration
# =============================================================================

# Default models per agent (can be overridden in code)
# =============================================================================
# AI Co-Scientist Model Configuration (Jan 2026 - Gemini Stack)
# =============================================================================

# 1. THE "BRAIN" (High Intelligence, 2M+ Context)
# Used for: Generation, Evolution, Meta-Review
# Why: "Best in the world for multimodal understanding... and agentic tasks."
# Cost: $2.00 / 1M (Paid)
GENERATION_MODEL=gemini-3-pro-preview
EVOLUTION_MODEL=gemini-3-pro-preview
META_REVIEW_MODEL=gemini-3-pro-preview
REFLECTION_MODEL=gemini-2.5-flash
RANKING_MODEL=gemini-3-flash-preview
PROXIMITY_MODEL=gemini-3-flash-preview
SUPERVISOR_MODEL=gemini-3-flash-preview

# Alternative: Use Gemini for cost savings
# GENERATION_MODEL=gemini-2.0-flash
# REFLECTION_MODEL=gemini-2.0-flash

# =============================================================================
# Budget & Cost Tracking
# =============================================================================

# Maximum budget in AUD - system stops when exceeded
BUDGET_LIMIT_AUD=50.0

# USD to AUD conversion rate (update periodically)
USD_TO_AUD_RATE=1.55

# Path to persist cost tracking data
COST_TRACKING_PATH=./data/cost_tracking.json

# =============================================================================
# System Settings
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum concurrent agent workers
MAX_WORKERS=4

# Tournament settings
INITIAL_ELO_RATING=1200
ELO_K_FACTOR=32
