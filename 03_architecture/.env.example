# AI Co-Scientist Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# =============================================================================
# LLM Providers
# =============================================================================

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google AI (Gemini) - https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSyAEUaXDkdB9OgDvEsLwda7ZVtyIVgguMHg

# OpenAI (optional fallback) - https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# =============================================================================
# LangSmith (Optional - for LangGraph tracing/debugging)
# =============================================================================

# LangSmith - https://smith.langchain.com/
# Free tier available, useful for debugging agent workflows
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=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
LANGCHAIN_PROJECT=ai-coscientist

# =============================================================================
# Search & RAG
# =============================================================================

# Tavily Search API - https://tavily.com/
TAVILY_API_KEY=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

# =============================================================================
# Storage Backend (Phase 4)
# =============================================================================

# Storage backend: "memory" (dev), "postgres" (prod), "cached" (prod + Redis)
STORAGE_BACKEND=memory

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://coscientist:password@localhost:5432/coscientist

# Redis connection string (for caching/task queue)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Vector Storage
# =============================================================================

# ChromaDB (prototyping) - local file path
CHROMA_PERSIST_DIRECTORY=./data/chroma

# =============================================================================
# Model Configuration
# =============================================================================

# LLM Provider: "google" or "openai"
# This determines which model preset is used for all agents
LLM_PROVIDER=google

# -----------------------------------------------------------------------------
# GOOGLE GEMINI MODELS (if LLM_PROVIDER=google)
# -----------------------------------------------------------------------------
# Pricing (USD per 1M tokens): input / output
#   gemini-3-pro-preview:   $2.00 / $12.00  (best quality)
#   gemini-2.5-flash:       $0.30 / $2.50   (balanced)
#   gemini-3-flash-preview: $0.50 / $3.00   (fast)
#   gemini-2.0-flash:       $0.10 / $0.40   (cheapest)

GOOGLE_GENERATION_MODEL=gemini-3-pro-preview
GOOGLE_EVOLUTION_MODEL=gemini-3-pro-preview
GOOGLE_META_REVIEW_MODEL=gemini-3-pro-preview
GOOGLE_REFLECTION_MODEL=gemini-2.5-flash
GOOGLE_RANKING_MODEL=gemini-3-flash-preview
GOOGLE_PROXIMITY_MODEL=gemini-3-flash-preview
GOOGLE_SUPERVISOR_MODEL=gemini-3-flash-preview

# -----------------------------------------------------------------------------
# OPENAI MODELS (if LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
# Pricing (USD per 1M tokens): input / output
#   gpt-5.1:      $1.25 / $10.00  (best quality for budget)
#   gpt-5:        $1.25 / $10.00  (stable)
#   gpt-5-mini:   $0.25 / $2.00   (balanced)
#   gpt-5-nano:   $0.05 / $0.40   (cheapest)
#   gpt-5.2:      $1.75 / $14.00  (premium, not recommended for budget)
#   gpt-5-pro:    $21.00 / $168.00 (too expensive)

OPENAI_GENERATION_MODEL=gpt-5.1
OPENAI_EVOLUTION_MODEL=gpt-5.1
OPENAI_META_REVIEW_MODEL=gpt-5
OPENAI_REFLECTION_MODEL=gpt-5-mini
OPENAI_RANKING_MODEL=gpt-5-mini
OPENAI_PROXIMITY_MODEL=gpt-5-nano
OPENAI_SUPERVISOR_MODEL=gpt-5-nano

# =============================================================================
# Budget & Cost Tracking
# =============================================================================

# Maximum budget in AUD - system stops when exceeded
BUDGET_LIMIT_AUD=15

# USD to AUD conversion rate (update periodically)
USD_TO_AUD_RATE=1.55

# Path to persist cost tracking data
COST_TRACKING_PATH=./data/cost_tracking.json

# =============================================================================
# System Settings
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum concurrent agent workers
MAX_WORKERS=4

# Tournament settings
INITIAL_ELO_RATING=1200
ELO_K_FACTOR=32
